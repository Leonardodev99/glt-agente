{
  "expo": {
    "name": "gtl-agente",
    "slug": "gtl-agente",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "gtlagente",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.gtlagente"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.gtlagente"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "expo": {
      "plugins": [
        [
          "expo-location",
          {
            "locationAlwaysAndWhenInUsePermission": "Permitir que o app use sua localização para registrar ocorrências."
          }
        ]
      ]
    }
  }
}
